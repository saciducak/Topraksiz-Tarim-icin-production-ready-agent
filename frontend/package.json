        "@types/three": "^0.182.0",
        "axios": "^1.6.0",
        "clsx": "^2.1.1",
        "framer-motion": "^10.16.4",
        "maath": "^0.10.8",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-dropzone": "^14.2.3",
        "react-icons": "^4.11.0",
        "react-markdown": "^9.0.0",
        "react-router-dom": "^6.20.0",
        "recharts": "^2.9.0",
        "tailwind-merge": "^3.4.0",
        "three": "^0.182.0"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/jest-dom": "^6.9.1",
